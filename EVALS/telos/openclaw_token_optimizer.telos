# openclaw_token_optimizer.telos — Minimize fleet LLM cost across 3 providers
#
# Variables: alloc_* = fraction of fleet runs routed to each provider
# Parameters: cost, availability, and budget data from OpenClaw
# Objective: minimize total daily token cost
# Constraints: budget cap, provider availability, quota guard, diversity
#
# Part of the Telos OS experiment in AI Workforce Lab.
# See: EVALS/telos/README.md

ontology:
  variables:
    - name: alloc_anthropic
      type: float
      bounds: [0.0, 1.0]
    - name: alloc_openai
      type: float
      bounds: [0.0, 1.0]
    - name: alloc_google
      type: float
      bounds: [0.0, 1.0]
  parameters:
    - cost_per_run_anthropic
    - cost_per_run_openai
    - cost_per_run_google
    - daily_runs
    - daily_budget
    - anthropic_remaining_pct
    - openai_available
    - google_available

teleology:
  direction: minimize
  objective: "cost_per_run_anthropic * alloc_anthropic * daily_runs + cost_per_run_openai * alloc_openai * daily_runs + cost_per_run_google * alloc_google * daily_runs"

invariants:
  # All traffic must be allocated (fractions sum to 1)
  - type: eq
    expression: "alloc_anthropic + alloc_openai + alloc_google - 1.0"

  # Stay within daily variable token budget
  - type: ineq
    expression: "daily_budget - (cost_per_run_anthropic * alloc_anthropic + cost_per_run_openai * alloc_openai + cost_per_run_google * alloc_google) * daily_runs"

  # Don't over-allocate to Anthropic when monthly quota is low
  # remaining_pct (0-100) directly caps the max allocation fraction
  # e.g., 5% remaining → max 5% of runs on Anthropic
  - type: ineq
    expression: "anthropic_remaining_pct * 0.01 - alloc_anthropic"

  # Can't route to a provider that is down (available = 0 caps alloc to 0)
  - type: ineq
    expression: "openai_available - alloc_openai"

  - type: ineq
    expression: "google_available - alloc_google"
